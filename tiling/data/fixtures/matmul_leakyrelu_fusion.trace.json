    "lines": [
      {"line": 13, "text": "* \\brief 基于静态Tensor编程模式实现Matmul和LeakyRelu融合计算，展示Cube单元和Vector单元协同计算的编程模式。"},
      {"line": 36, "text": "    if ASCEND_IS_AIC {"},
      {"line": 39, "text": "    if ASCEND_IS_AIV {"},
      {"line": 49, "text": "        // Matmul计算场景内存分配，需要在aic侧执行"},
      {"line": 59, "text": "        // Vector计算场景内存分配，需要在aiv侧执行"},
      {"line": 66, "text": "                if ASCEND_IS_AIC {"},
      {"line": 68, "text": "                        CopyInA(a1Local, kIndex, mIndex);"},
      {"line": 69, "text": "                        CopyInB(b1Local, kIndex, nIndex);"},
      {"line": 80, "text": "                        Compute(cLocal, a2Local, b2Local, kIndex, mIndex, nIndex);"},
      {"line": 87, "text": "                    CopyOut(cLocal, mIndex, nIndex);"},
      {"line": 89, "text": "                    AscendC::CrossCoreSetFlag<0x2, PIPE_FIX>(0);"},
      {"line": 91, "text": "                if ASCEND_IS_AIV {"},
      {"line": 93, "text": "                    AscendC::CrossCoreWaitFlag(0);"},
      {"line": 95, "text": "                    LeaklyGeluCompute(vecLocal, mIndex, nIndex, baseM / 2 * baseN);"},
      {"line": 103, "text": "        uint32_t mIterIdx = AscendC::GetBlockIdx() % mIter;"},
      {"line": 117, "text": "        uint32_t mIterIdx = AscendC::GetBlockIdx() / 2 % mIter;"},
      {"line": 246, "text": "        uint32_t gmOffset = (mIndex * baseM * N + nIndex * baseN) + AscendC::GetBlockIdx() % 2 * (baseM / 2 * N);"},
      {"line": 248, "text": "        AscendC::DataCopyPad<half>(vecLocal, cGM[gmOffset], copyParams, padParams);"},
      {"line": 255, "text": "        AscendC::LeakyRelu(vecLocal, vecLocal, (half)0.001, tileLen);"},
      {"line": 262, "text": "        AscendC::DataCopyPad<half>(cGM[gmOffset], vecLocal, copyParams);"},
      {"line": 274, "text": "__global__ __mix__(1, 2) void mmad_vec_custom(GM_ADDR a, GM_ADDR b, GM_ADDR c)"}
    ]
