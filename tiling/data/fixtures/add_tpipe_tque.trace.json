      {"line": 26, "text": "struct AddCustomTilingData {"},
      {"line": 27, "text": "    uint32_t totalLength;"},
      {"line": 28, "text": "    uint32_t tileNum;"},
      {"line": 33, "text": "__aicore__ inline void Init(GM_ADDR x, GM_ADDR y, GM_ADDR z, uint32_t totalLength, uint32_t tileNum)"},
      {"line": 35, "text": "    this->blockLength = totalLength / AscendC::GetBlockNum();"},
      {"line": 37, "text": "    this->tileLength = this->blockLength / tileNum / BUFFER_NUM;"},
      {"line": 38, "text": "    xGm.SetGlobalBuffer((__gm__ float*)x + this->blockLength * AscendC::GetBlockIdx(), this->blockLength);"},
      {"line": 41, "text": "    pipe.InitBuffer(inQueueX, BUFFER_NUM, this->tileLength * sizeof(float));"},
      {"line": 45, "text": "__aicore__ inline void Process()"},
      {"line": 47, "text": "    int32_t loopCount = this->tileNum * BUFFER_NUM;"},
      {"line": 49, "text": "        CopyIn(i);"},
      {"line": 50, "text": "        Compute(i);"},
      {"line": 51, "text": "        CopyOut(i);"},
      {"line": 56, "text": "__aicore__ inline void CopyIn(int32_t progress)"},
